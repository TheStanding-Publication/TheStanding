layout: layouts/base.njk
title: Corrections
permalink: /corrections/index.html
---

<h1>Corrections and retractions</h1>
<p>
  Every correction or retraction the publication has issued. We do not silently
  edit the historical record: minor edits are logged in the entry's correction
  log; substantive corrections are issued as new entries that reference the
  original, with both kept live forever.
</p>

<section class="corrections-submit">
  <h2>How to submit a correction</h2>
  <p>
    We welcome corrections from anyone. There are two ways to reach us:
    open a <a href="https://github.com/TheStanding-Publication/TheStanding/issues/new?template=correction.yml">correction request on GitHub</a>
    (preferred — it walks you through everything we need), or email
    <a href="mailto:{{ site.editorEmail }}">{{ site.editorEmail }}</a>.
  </p>
  <p>
    Please include the URL of the entry, the specific text or claim that is wrong,
    what it should say instead if you know it, and a source that establishes the
    correct fact. Our <a href="/standards/#sourcing">sourcing standard</a> requires
    at least one primary source (court filing, agency record, transcript, or
    citizen-captured documentation) or two independent investigative outlets.
  </p>
  <p>
    Once verified, substantive corrections and retractions are published as new
    entries that reference the original; minor edits are logged in the affected
    entry's correction log. Nothing is changed silently and every correction stays
    live permanently. See our full
    <a href="/standards/#corrections-and-retractions">corrections and retractions protocol</a>
    for what we will and won't correct.
  </p>
</section>

{% set correctedEntries = collections.entries | selectattr("data.relationships.corrects") %}
{% set retractedEntries = collections.entries | selectattr("data.relationships.retracts") %}

<section>
  <h2>Substantive corrections</h2>
  {% set hasCorrections = false %}
  {% for entry in collections.entries %}
    {% if entry.data.relationships and entry.data.relationships.corrects and entry.data.relationships.corrects.length %}
      {% set hasCorrections = true %}
      {% include "partials/entry-card.njk" %}
    {% endif %}
  {% endfor %}
  {% if not hasCorrections %}<p><em>None to date.</em></p>{% endif %}
</section>

<section>
  <h2>Retractions</h2>
  {% set hasRetractions = false %}
  {% for entry in collections.entries %}
    {% if entry.data.relationships and entry.data.relationships.retracts and entry.data.relationships.retracts.length %}
      {% set hasRetractions = true %}
      {% include "partials/entry-card.njk" %}
    {% endif %}
  {% endfor %}
  {% if not hasRetractions %}<p><em>None to date.</em></p>{% endif %}
</section>

<section>
  <h2>In-place edits (correction log)</h2>
  {% set hasEdits = false %}
  {% for entry in collections.entries %}
    {% if entry.data.corrections and entry.data.corrections.length %}
      {% set hasEdits = true %}
      <article>
        <h3><a href="{{ entry.url }}">{{ entry.data.headline }}</a></h3>
        <ul>
          {% for c in entry.data.corrections %}
            <li><time>{{ c.date | formatDate }}</time>: {{ c.note }}</li>
          {% endfor %}
        </ul>
      </article>
    {% endif %}
  {% endfor %}
  {% if not hasEdits %}<p><em>None to date.</em></p>{% endif %}
</section>
